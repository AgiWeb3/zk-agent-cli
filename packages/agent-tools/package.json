{
  "name": "@zk-agent/agent-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && node --import tsx --test ./tests/*.test.ts",
    "smoke:operator-path": "node --import tsx ./src/smoke-operator-path.ts",
    "smoke:readonly": "node --import tsx ./src/smoke-readonly.ts",
    "smoke:lifecycle": "node --import tsx ./src/smoke-lifecycle.ts",
    "smoke:policy": "node --import tsx ./src/smoke-policy.ts",
    "smoke:broadcast": "node --import tsx ./src/smoke-broadcast.ts",
    "smoke:paymaster-success": "node --import tsx ./src/smoke-paymaster-success.ts",
    "smoke:withdraw-followup": "node --import tsx ./src/smoke-withdraw-followup.ts",
    "tool:run": "node --import tsx ./src/run-tool.ts"
  },
  "dependencies": {
    "@zk-agent/account-profiles": "workspace:*",
    "@zk-agent/agent-core": "workspace:*",
    "@zk-agent/agent-session-protocol": "workspace:*",
    "@zk-agent/provider-zksync-defi": "workspace:*",
    "@zk-agent/provider-zksync-wallet": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
